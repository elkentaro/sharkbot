[Unit]
Description=SharkBot Wireshark Receiver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sharkbot
Group=sharkbot
WorkingDirectory=/mnt/usb/sharkbot
Environment=PYTHONUNBUFFERED=1
Environment=SMART_FILTER_CONFIG=/mnt/usb/sharkbot/config.toml
ExecStart=/mnt/usb/sharkbot/.venv/bin/python /mnt/usb/sharkbot/receiver_app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
