[receiver]
host = "127.0.0.1"
# Optional: bind to all interfaces for remote Wireshark clients.
# bind_host = "0.0.0.0"
# Optional: the URL the Wireshark client browser should open.
# public_base_url = "http://192.168.1.50:8765"
port = 8765

[defaults]
provider = "rule_based"
model = "builtin"

[assistant]
profile = "specialist"
name = "SharkBot"
# Built-in profiles:
# - "specialist" (packet analyst + incident response)
# - "packet_analyst"
# - "incident_response"
# Optional: add site-specific analyst guidance inline.
# custom_instructions = """
# Prioritize suspicious east-west traffic, credential misuse, and lateral movement indicators.
# Prefer Wireshark display filters that an analyst can paste directly into the filter bar.
# """
# Optional: load longer analyst instructions from a separate file.
# prompt_file = "assistant_prompt.txt"

[providers.openai]
api_key = ""

[providers.anthropic]
api_key = ""

[providers.gemini]
api_key = ""

[providers.ollama]
# Uncomment if you want Ollama available in the UI and for automatic fallback.
# base_url = "http://127.0.0.1:11434"

[advanced]
timeout_seconds = 45
